FROM node:20-alpine AS builder
WORKDIR /app

ARG SERVER_URL=""
ENV EXPO_PUBLIC_SERVER_URL=$SERVER_URL

COPY package*.json ./
COPY scripts/ ./scripts/
RUN npm ci --legacy-peer-deps

COPY . .
# Strip native-only plugins from app.json before web export
RUN python3 -c "
import json
with open('app.json') as f: cfg = json.load(f)
cfg['expo']['plugins'] = ['expo-router']
with open('app.json', 'w') as f: json.dump(cfg, f)
"
RUN npx expo export --platform web

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.web.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
