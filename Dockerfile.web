FROM node:20-alpine AS builder
WORKDIR /app

COPY package*.json ./
COPY scripts/ ./scripts/
RUN npm ci --legacy-peer-deps

COPY . .
# Strip native-only plugins from app.json before web export
RUN node -e "const fs=require('fs');const d=JSON.parse(fs.readFileSync('app.json'));d.expo.plugins=['expo-router'];fs.writeFileSync('app.json',JSON.stringify(d))"
RUN npx expo export --platform web

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.web.conf /etc/nginx/conf.d/default.conf
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh
EXPOSE 80
ENTRYPOINT ["/docker-entrypoint.sh"]
